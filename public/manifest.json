{
  "manifest_version": 3,
  "name": "OmniMail",
  "version": "1.0.0",
  "description": "네이버 및 Gmail 실시간 통합 메일 대시보드 크롬 확장 프로그램",
  "permissions": [
    "cookies",
    "storage",
    "alarms",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],
  "optional_host_permissions": [
    "*://*.naver.com/*",
    "*://mail.naver.com/*",
    "*://nid.naver.com/*",
    "*://mail.google.com/*",
    "*://accounts.google.com/*",
    "*://*.google.com/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "OmniMail 대시보드"
  }
}
